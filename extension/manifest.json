{
  "manifest_version": 3,
  "name": "PhishNet — AI Phishing Detector",
  "version": "1.0.0",
  "description": "Detects phishing URLs using BERT + Random Forest hybrid AI. Shows WHY a URL is suspicious.",
  "permissions": [
    "activeTab",
    "storage"
  ],
 "host_permissions": ["https://irbxrocket-phishnet-api.hf.space/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}